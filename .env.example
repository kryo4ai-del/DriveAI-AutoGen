# DriveAI-AutoGen — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at startup.

# ── OpenAI API Key ──────────────────────────────────────────────────────────
# Required for all LLM environment profiles (dev, test, prod).
# Obtain your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional: Additional API keys for custom profiles ───────────────────────
# If you add a profile in config/llm_profiles.json that uses a different
# api_key_env name, define that variable here.
# Example:
# OPENAI_API_KEY_PROD=your_production_key_here
