# DriveAI-AutoGen — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at startup.

# ── Anthropic API Key (PRIMARY) ──────────────────────────────────────────────
# Required for all Claude models (Haiku, Sonnet, Opus).
# Obtain your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI API Key (LEGACY/OPTIONAL) ────────────────────────────────────────
# Only needed if you use legacy_dev or legacy_prod profiles.
# OPENAI_API_KEY=your_openai_api_key_here
