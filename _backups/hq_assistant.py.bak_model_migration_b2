def handle_tool_call(tool_name: str, tool_input: dict) -> str:
    """Dispatch tool calls to factory modules."""
    try:
        if tool_name == "get_project_status":
            from factory.project_registry import get_project
            result = get_project(tool_input.get("slug", ""))
            return json.dumps(result, indent=2, default=str) if result else '{"error": "Projekt nicht gefunden"}'

        elif tool_name == "list_all_projects":
            from factory.project_registry import list_projects
            projects = list_projects()
            summary = [{"id": p.get("project_id"), "title": p.get("title"), "status": p.get("status"),
                         "phase": p.get("current_phase"), "mode": p.get("mode")} for p in projects]
            return json.dumps(summary, indent=2, default=str)

        elif tool_name == "get_health_alerts":
            from factory.hq.health_monitor import run_health_check
            return json.dumps(run_health_check(), indent=2, default=str)

        elif tool_name == "run_auto_repair":
            from factory.hq.auto_repair import run_auto_repair
            return json.dumps(run_auto_repair(), indent=2, default=str)

        elif tool_name == "get_factory_health":
            from factory.hq.assistant.context_builder import read_factory_health
            return read_factory_health()

        elif tool_name == "get_cost_summary":
            from factory.hq.assistant.context_builder import build_cost_summary
            return build_cost_summary(tool_input.get("slug"))

        elif tool_name == "get_ceo_briefing":
            from factory.hq.assistant.context_builder import build_ceo_briefing
            return build_ceo_briefing()

        elif tool_name == "get_welcome_briefing":
            from factory.hq.assistant.context_builder import build_welcome_briefing
            return build_welcome_briefing()

        elif tool_name == "get_team_overview":
            from factory.agent_registry import get_all_agents, get_agents_by_department, get_agents_by_provider, get_summary
            dept = tool_input.get("department")
            prov = tool_input.get("provider")
            if dept:
                agents = get_agents_by_department(dept)
            elif prov:
                agents = get_agents_by_provider(prov)
            else:
                agents = get_all_agents()
            return json.dumps({"summary": get_summary(), "agents": [{"id": a["id"], "name": a["name"], "role": a["role"], "department": a["department"], "model": a.get("default_model"), "provider": a.get("provider"), "status": a["status"]} for a in agents]}, indent=2, default=str)

        elif tool_name == "get_provider_status":
            from factory.hq.providers.balance_monitor import check_all_providers
            result = check_all_providers()
            pid = tool_input.get("provider_id")
            if pid:
                result["providers"] = [p for p in result["providers"] if p["id"] == pid]
            return json.dumps(result, indent=2, default=str)

        elif tool_name == "update_provider_balance":
            from factory.hq.providers.balance_monitor import update_manual_balance
            return json.dumps(update_manual_balance(
                tool_input["provider_id"], tool_input["balance"]
            ), indent=2, default=str)

        elif tool_name == "get_pending_gates_list":
            from factory.hq.gate_api import get_pending_gates
            gates = get_pending_gates(
                project=tool_input.get("project"),
                category=tool_input.get("category"),
            )
            summary = [{"gate_id": g["gate_id"], "title": g["title"], "severity": g["severity"],
                         "project": g["project"], "category": g["category"], "platform": g.get("platform"),
                         "options": [o["id"] for o in g.get("options", [])],
                         "recommendation": g.get("recommendation", {}).get("option_id")} for g in gates]
            return json.dumps(summary, indent=2, default=str)

        # --- Action Tools ---
        elif tool_name == "set_gate_decision":
            gate_id = tool_input.get("gate_id")
            decision = tool_input["decision"]
            notes = tool_input.get("notes", "")

            # New system: use gate_id directly
            if gate_id:
                from factory.hq.gate_api import decide_gate
                return json.dumps(decide_gate(gate_id, decision, notes), indent=2, default=str)

            # Legacy: find gate by project+type
            slug = tool_input.get("slug", "")
            gate_type = tool_input.get("gate_type", "")
            if slug and gate_type:
                from factory.hq.gate_api import get_pending_gates
                matching = [g for g in get_pending_gates(project=slug) if g["gate_type"] == gate_type]
                if matching:
                    from factory.hq.gate_api import decide_gate
                    return json.dumps(decide_gate(matching[0]["gate_id"], decision, notes), indent=2, default=str)

            # Fallback to old executor
            from factory.hq.assistant.action_executor import execute_gate_decision
            return json.dumps(execute_gate_decision(
                slug, gate_type, decision, notes
            ), indent=2, default=str)

        elif tool_name == "start_pipeline":
            from factory.hq.assistant.action_executor import start_pipeline_phase
            return json.dumps(start_pipeline_phase(
                tool_input["slug"], tool_input["phase"], tool_input.get("mode")
            ), indent=2, default=str)

        elif tool_name == "get_pipeline_log":
            from factory.hq.assistant.action_executor import get_pipeline_log
            return json.dumps(get_pipeline_log(
                tool_input["slug"], tool_input.get("lines", 20)
            ), indent=2, default=str)

        elif tool_name == "delete_projects":
            if not tool_input.get("confirmed"):
                return json.dumps({"error": "Loeschung nicht bestaetigt. CEO muss explizit bestaetigen."})
            from factory.hq.assistant.action_executor import delete_projects
            return json.dumps(delete_projects(
                tool_input["slugs"], tool_input["confirmed"]
            ), indent=2, default=str)

        elif tool_name == "archive_project":
            from factory.hq.assistant.action_executor import archive_project
            return json.dumps(archive_project(
                tool_input["slug"], tool_input.get("reason", "")
            ), indent=2, default=str)

        elif tool_name == "create_new_project":
            from factory.hq.assistant.action_executor import create_new_project
            return json.dumps(create_new_project(
                tool_input["title"], tool_input["idea_text"],
                tool_input["mode"], tool_input.get("auto_start", False)
            ), indent=2, default=str)

        # --- Janitor Tools ---
        elif tool_name == "get_janitor_status":
            from factory.hq.janitor.janitor import get_status
            result = get_status()
            return json.dumps(result, indent=2, ensure_ascii=False, default=str)

        elif tool_name == "run_janitor_scan":
            level = tool_input.get("level", "daily")
            if level == "daily":
                from factory.hq.janitor.janitor import run_daily
                result = run_daily()
            elif level == "weekly":
                from factory.hq.janitor.janitor import run_weekly
                result = run_weekly()
            elif level == "monthly":
                from factory.hq.janitor.janitor import run_monthly
                result = run_monthly()
            else:
                return json.dumps({"error": f"Unknown level: {level}"})
            summary = result.get("summary", {})
            return json.dumps({
                "cycle": level,
                "health_score": summary.get("health_score"),
                "findings": summary.get("total_findings", 0),
                "green": summary.get("green_auto_fixable", 0),
                "yellow": summary.get("yellow_proposals", 0),
                "red": summary.get("red_report_only", 0),
                "auto_fixed": len(result.get("actions", {}).get("auto_fixed", [])),
                "proposed": len(result.get("actions", {}).get("proposed", [])),
                "cost_usd": result.get("cost_usd", 0),
            }, indent=2, default=str)

        # --- TheBrain Tools ---
        elif tool_name == "brain_briefing":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().factory_briefing()

        elif tool_name == "brain_diagnose":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().factory_diagnose()

        elif tool_name == "brain_gaps":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().factory_gaps()

        elif tool_name == "brain_roadmap":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().factory_roadmap()

        elif tool_name == "brain_quick_check":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().factory_quick_check()

        elif tool_name == "brain_commands":
            from factory.hq.assistant.brain_tools import get_brain_tools
            return get_brain_tools().get_available_commands()

        # --- Memory Tools ---
        elif tool_name == "get_memory":
            memory = _load_memory()
            return json.dumps(memory, indent=2, ensure_ascii=False, default=str)

        elif tool_name == "update_memory_manual":
            memory = _load_memory()
            category = tool_input["category"]
            action = tool_input["action"]
            content = tool_input["content"]

            if category in memory and isinstance(memory[category], list):
                if action == "add":
                    memory[category].append(content)
                    if len(memory[category]) > 10:
                        memory[category] = memory[category][-10:]
                elif action == "remove":
                    memory[category] = [
                        item for item in memory[category]
                        if content.lower() not in item.lower()
                    ]
            _save_memory(memory)
            return json.dumps({"success": True, "action": action, "category": category, "content": content})

    except Exception as e:
        return json.dumps({"error": str(e)})

    return json.dumps({"error": f"Unknown tool: {tool_name}"})


def chat(user_message: str, history: list = None) -> tuple:
    """Main chat function. Returns (response_text, updated_history)."""
    global _message_counter
    import anthropic

    client = anthropic.Anthropic()
    messages = list(history or [])
    messages.append({"role": "user", "content": user_message})

    # Build system prompt with memory
    system = _build_system_prompt()

    # First API call
    response = client.messages.create(
        model=ASSISTANT_MODEL,
        max_tokens=2048,
        system=system,
        tools=TOOLS,
        messages=messages,
    )

    # Tool use loop
    while response.stop_reason == "tool_use":
        tool_blocks = [b for b in response.content if b.type == "tool_use"]
        messages.append({"role": "assistant", "content": response.content})

        tool_results = []
        for tb in tool_blocks:
            result_str = handle_tool_call(tb.name, tb.input)
            # Truncate very long results
            if len(result_str) > 8000:
                result_str = result_str[:8000] + "\n... (truncated)"
            tool_results.append({
                "type": "tool_result",
                "tool_use_id": tb.id,
                "content": result_str,
            })

        messages.append({"role": "user", "content": tool_results})

        response = client.messages.create(
            model=ASSISTANT_MODEL,
            max_tokens=2048,
            system=system,
            tools=TOOLS,
            messages=messages,
        )

    # Extract final text
    text = ""
    for block in response.content:
        if hasattr(block, "text"):
            text += block.text

    messages.append({"role": "assistant", "content": response.content})

    # Memory auto-update every N messages
    _message_counter += 1
    if _message_counter % MEMORY_UPDATE_INTERVAL == 0:
        try:
            _update_memory(messages)
        except Exception:
            pass  # Non-blocking

    return text, messages


def extract_speak_text(response_text: str) -> tuple:
    """Extract <speak>...</speak> block from response.

    Returns (clean_text, speak_text) where:
    - clean_text: response without <speak> tags
    - speak_text: extracted spoken text (or None)
    """
    match = re.search(r"<speak>(.*?)</speak>", response_text, re.DOTALL)
    if not match:
        return response_text, None

    speak_text = match.group(1).strip()

    # Remove the <speak> block from the displayed text
    clean_text = response_text[:match.start()] + response_text[match.end():]
    # Clean up double spaces / double newlines left behind
    clean_text = re.sub(r"  +", " ", clean_text)
    clean_text = re.sub(r"\n{3,}", "\n\n", clean_text)
    clean_text = clean_text.strip()

    # Safety: enforce max length
    if len(speak_text) > 300:
        speak_text = speak_text[:300]

    return clean_text, speak_text
