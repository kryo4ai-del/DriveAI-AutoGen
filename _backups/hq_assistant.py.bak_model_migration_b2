def _load_memory() -> dict:
    """Laedt das persistente Memory aus memory.json."""
    if MEMORY_FILE.exists():
        try:
            with open(MEMORY_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            return {}
    return {}


def _save_memory(memory: dict):
    """Schreibt Memory in memory.json."""
    memory["last_updated"] = datetime.now(timezone.utc).isoformat()
    with open(MEMORY_FILE, "w", encoding="utf-8") as f:
        json.dump(memory, f, indent=2, ensure_ascii=False)


def _build_system_prompt() -> str:
    """Baut den System-Prompt mit aktuellem Memory."""
    memory = _load_memory()
    if not memory or not memory.get("summary"):
        return SYSTEM_PROMPT

    topics = "\n".join("- " + t for t in memory.get("active_topics", []))
    decisions = "\n".join(
        "- " + d["date"] + ": " + d["decision"] + (" (" + d.get("project", "") + ")" if d.get("project") else "")
        for d in memory.get("recent_decisions", [])[-10:]
    )
    prefs = "\n".join("- " + p for p in memory.get("ceo_preferences", []))
    ctx = "\n".join("- " + c for c in memory.get("important_context", []))

    memory_block = f"""

DEIN GEDAECHTNIS -- Was du aus frueheren Gespraechen weisst:

Zusammenfassung: {memory.get('summary', '')}

Aktuelle Themen:
{topics}

Letzte CEO-Entscheidungen:
{decisions}

CEO-Praeferenzen:
{prefs}

Wichtiger Kontext:
{ctx}

Bisherige Interaktionen: {memory.get('interaction_count', 0)} Nachrichten in {memory.get('sessions_count', 0)} Sessions.

WICHTIG: Nutze dieses Wissen natuerlich. Sage NICHT 'laut meinem Gedaechtnis' oder 'ich erinnere mich'. Sprich so als wuesstest du es einfach -- wie ein Kollege der gestern auch da war."""

    return SYSTEM_PROMPT + memory_block


def _extract_text(content) -> str:
    """Extrahiert Text aus verschiedenen Message-Formaten."""
    if isinstance(content, str):
        return content[:200]
    if isinstance(content, list):
        texts = []
        for block in content:
            if hasattr(block, "text"):
                texts.append(block.text[:200])
            elif isinstance(block, dict) and block.get("type") == "text":
                texts.append(block.get("text", "")[:200])
        return " ".join(texts)
    return str(content)[:200]


def _update_memory(history: list):
    """Generiert ein Memory-Update aus der Chat-History via Haiku (guenstig)."""
    import anthropic

    memory = _load_memory()

    # Nur die letzten 10 Nachrichten als Kontext
    recent = history[-10:] if len(history) > 10 else history
    lines = []
    for m in recent:
        role = "CEO" if m.get("role") == "user" else "Assistant"
        txt = _extract_text(m.get("content", ""))
        if txt.strip():
            lines.append(f"{role}: {txt}")
    recent_text = "\n".join(lines)

    if not recent_text.strip():
        return

    update_prompt = f"""Analysiere dieses Gespraech und aktualisiere das Memory des Assistenten.

AKTUELLES MEMORY:
{json.dumps(memory, indent=2, ensure_ascii=False)}

NEUE NACHRICHTEN:
{recent_text}

Gib ein aktualisiertes Memory als JSON zurueck. Regeln:
- summary: 1-2 Saetze, was insgesamt passiert ist (alt + neu zusammenfassen), max 500 Zeichen
- active_topics: Max 5 aktuelle Themen (alte die erledigt sind entfernen, neue hinzufuegen)
- recent_decisions: Neue CEO-Entscheidungen hinzufuegen (max 15 behalten, aelteste entfernen)
- ceo_preferences: Neue Praeferenzen hinzufuegen wenn erkennbar (max 10)
- important_context: Aktualisieren wenn sich etwas geaendert hat (max 10)
- interaction_count: um die Anzahl neuer Nachrichten erhoehen
- sessions_count: beibehalten (wird extern gezaehlt)

NUR das JSON zurueckgeben, kein anderer Text. Kein Markdown-Fence."""

    try:
        client = anthropic.Anthropic()
        response = client.messages.create(
            model="claude-haiku-4-5",
            max_tokens=1024,
            messages=[{"role": "user", "content": update_prompt}],
        )

        raw = response.content[0].text.strip()
        # Strip markdown fence if present
        if raw.startswith("```"):
            raw = re.sub(r"^```\w*\n?", "", raw)
            raw = re.sub(r"\n?```$", "", raw)

        updated_memory = json.loads(raw)
        updated_memory["last_updated"] = datetime.now(timezone.utc).isoformat()
        updated_memory["version"] = memory.get("version", 0) + 1
        _save_memory(updated_memory)
        logger.info("Memory updated (v%s)", updated_memory["version"])
    except Exception as e:
        logger.warning("Memory update failed: %s", e)


