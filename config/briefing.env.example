# Daily Briefing — Delivery Config
# Copy to briefing.env and fill in values.

# --- Email (SMTP) ---
BRIEFING_SMTP_HOST=smtp.gmail.com
BRIEFING_SMTP_PORT=587
BRIEFING_SMTP_USER=your-email@gmail.com
BRIEFING_SMTP_PASS=your-app-password
BRIEFING_EMAIL_FROM=your-email@gmail.com
BRIEFING_EMAIL_TO=your-email@gmail.com

# --- Google Sheets ---
BRIEFING_GSHEET_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_FILE=/opt/driveai-factory/config/google_sa.json
